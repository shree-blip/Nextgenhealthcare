# Copy to .env.local (gitignored) for local dev, and set the same vars in the
# Vercel project settings for production. DO NOT set NODE_ENV in Vercel —
# Vercel manages it automatically (production at runtime).

# ─── Database (Supabase Postgres) ───
# Pooled connection (pgBouncer) used by the app at runtime.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
# Direct (non-pooled) connection used by Prisma migrate / db push.
DIRECT_URL=postgresql://USER:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ─── Auth ───
# Secret for signing JWT auth cookies. Keep stable so existing cookies stay valid.
JWT_SECRET=
# Base URL of the deployed app — used to build the Google OAuth redirect_uri
# and the post-login redirect/postMessage origin. Must match the live domain.
APP_URL=https://thenextgenhealth.com

# ─── Google OAuth ("Continue with Google") ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI ───
# Gemini powers the chatbot + AI blog/news generators (required for those).
GEMINI_API_KEY=
# Optional: enables embedding-based RAG for the chatbot. Empty = keyword fallback.
OPENAI_API_KEY=

# ─── SMTP email (Gmail / Google Workspace app password) ───
# Powers auto-notifications for new contact leads + consultation bookings and
# the confirmation email sent to the submitter. Generate SMTP_PASS as a Google
# "App password" (Account → Security → 2-Step Verification → App passwords).
# If these are empty, leads/bookings are still saved but no email is sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=hello@thenextgenhealth.com
SMTP_PASS=
SMTP_FROM=NextGen Health <hello@thenextgenhealth.com>
# Inbox that receives new-lead / new-booking alerts (defaults to SMTP_USER).
LEADS_NOTIFY_EMAIL=hello@thenextgenhealth.com

# ─── File storage (Vercel Blob) ───
# Required in production for avatar/blog-image uploads. Get it from the Vercel
# project Storage tab. If empty, uploads fall back to the local filesystem,
# which does NOT work on Vercel serverless.
BLOB_READ_WRITE_TOKEN=
